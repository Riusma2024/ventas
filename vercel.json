{
  "rewrites": [
    { "source": "/api/test", "destination": "/api/test.js" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/test.js": { "memory": 1024, "maxDuration": 10 },
    "api/index.ts": { "memory": 1024, "maxDuration": 10 }
  }
}
